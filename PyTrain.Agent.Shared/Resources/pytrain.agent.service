[Unit]
Description=PyTrain is an open-source remote control and remote access solution.

[Service]
WorkingDirectory={{INSTALL_DIRECTORY}}
ExecStart={{INSTALL_DIRECTORY}}/PyTrain.Agent run{{INSTANCE_ARGS}}
Restart=always
KillMode=process
StartLimitIntervalSec=0
Environment=DOTNET_ENVIRONMENT=Production
RestartSec=10

[Install]
WantedBy=multi-user.target