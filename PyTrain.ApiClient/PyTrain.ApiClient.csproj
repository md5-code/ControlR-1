<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <Title>PyTrain API Client</Title>
    <Description>
      The API client for PyTrain, an open-source remote control and remote access solution.
    </Description>
    <PackageIcon>appicon.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IsNuGetPackage>true</IsNuGetPackage>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\.assets\appicon.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Update="README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Compliance.Redaction" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Update="Bitbound.Analyzers.MemberOrder">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference
      Include="..\Libraries\PyTrain.Libraries.Api.Contracts\PyTrain.Libraries.Api.Contracts.csproj" />
    <ProjectReference
      Include="..\Libraries\PyTrain.Libraries.DataRedaction\PyTrain.Libraries.DataRedaction.csproj" />
  </ItemGroup>
</Project>