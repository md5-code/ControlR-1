{
  "profiles": {
    "pytrain": {
      "commandName": "DockerCompose",
      "commandVersion": "1.0",
      "composeLaunchAction": "LaunchBrowser",
      "composeLaunchServiceName": "pytrain",
      "composeLaunchUrl": "http://localhost:5120/",
      "serviceActions": {
        "pytrain": "StartDebugging"
      }
    },
    "postgres": {
      "commandName": "DockerCompose",
      "commandVersion": "1.0",
      "composeLaunchAction": "DoNothing",
      "composeLaunchServiceName": "postgres",
      "serviceActions": {
        "postgres": "StartWithoutDebugging",
        "aspire": "StartWithoutDebugging",
        "pytrain": "DoNotStart"
      }
    }
  }
}